# MeditationOS — environment variable template
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ── Database (PostgreSQL) ───────────────────────────────
# Local dev via Docker Compose uses the `database` service host.
DATABASE_URL=postgresql://postgres:postgres@database:5432/meditationos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meditationos

# ── Backend (FastAPI) ───────────────────────────────────
# Generate a strong random value, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-to-a-random-secret
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
# JWT / session token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
# How long an emailed password-reset link stays valid, in minutes
PASSWORD_RESET_EXPIRE_MINUTES=30
# How long an email-verification link stays valid, in minutes (default 24h)
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
# Anti-spam: max rows a user may create per type (session/gratitude/journal/goal)
# per UTC day, before the API returns 429
DAILY_CREATE_LIMIT=200
# Per-IP burst limit on data-creation endpoints (slowapi syntax)
WRITE_RATE_LIMIT=60/minute
# Per-email login throttle: lock after N failed logins within the window (minutes)
LOGIN_MAX_FAILURES=10
LOGIN_FAILURE_WINDOW_MINUTES=15
# Trust X-Forwarded-For for client IP — ONLY enable behind a trusted reverse proxy
TRUST_PROXY=false
ENVIRONMENT=development
# "Sign in with Google" OAuth client ID (public). Create a Web OAuth client at
# https://console.cloud.google.com/apis/credentials and add http://localhost:5173
# as an authorized JavaScript origin. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=
# Comma-separated allowlist of admin email addresses. An account whose email is listed
# here is an admin (matched case-insensitively): it can reach /api/v1/admin/* and the
# frontend /admin dashboard. Migration-free, mirrors the env-config ethos. Empty = no
# admins. e.g. ADMIN_EMAILS=you@example.com,ops@example.com
ADMIN_EMAILS=

# ── Frontend (Vite) ─────────────────────────────────────
# Must be prefixed with VITE_ to be exposed to the client.
VITE_API_URL=http://localhost:8000/api/v1
# Same Google OAuth client ID as GOOGLE_CLIENT_ID above (safe to expose).
VITE_GOOGLE_CLIENT_ID=

# ── Product AI (V3 — Anthropic Claude) ──────────────────
# Powers the gratitude prompt suggestions (Claude Haiku). Leave blank to use the
# built-in curated suggestions instead — the feature works either way.
ANTHROPIC_API_KEY=

# ── Web Push (PWA notifications) ────────────────────────
# Optional. Leave blank to disable push (subscriptions still store; sends no-op —
# email reminders keep working). To enable: `pip install pywebpush`, generate keys
# with `npx web-push generate-vapid-keys`, and set both below. The public key is
# also exposed to the browser via GET /api/v1/push/config.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@meditationos.app

# ── Email (practice reminders) ──────────────────────────
# Outbound email for daily reminders (and, later, password reset). Leave SMTP_HOST
# blank to run in dev/no-provider mode: messages are logged, not sent, so the
# reminder loop still works locally. Point these at a provider's SMTP relay
# (SES, Postmark, …) in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=MeditationOS <noreply@meditationos.app>
# Public URL the frontend is served from — used for links inside emails.
APP_BASE_URL=http://localhost:5173
# Block accounts with an unconfirmed email (403) from all data routes; auth/verify
# routes stay open. Google sign-ins and guests arrive verified. Keep false until
# verification email delivery (SMTP_* above) is live and confirmed — turning it on
# without working email locks out every unconfirmed user.
REQUIRE_EMAIL_VERIFICATION=false

# ── Error Monitoring (Sentry) ───────────────────────────────────
# Optional. Leave blank to disable — the app runs exactly as today with no DSN.
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN).
# PII is scrubbed before events leave the process: no request bodies, no journal
# text, no emails, tokens, or cookies are transmitted.
SENTRY_DSN=
# Fraction of requests to trace for performance monitoring (0.0–1.0). Keep low.
SENTRY_TRACES_SAMPLE_RATE=0.05
# Frontend Sentry DSN — must be prefixed VITE_ to be exposed to the browser bundle.
VITE_SENTRY_DSN=
