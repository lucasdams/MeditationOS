# MeditationOS — LOCAL PRODUCTION environment template.
# Copy to `.env.prod`, set a strong SECRET_KEY, then run:
#   docker compose --env-file .env.prod -p medos-prod -f docker-compose.prod.yml up --build -d
# `.env.prod` is gitignored — NEVER commit real secrets.
#
# NOTE: the backend refuses to boot in ENVIRONMENT=production with dangerous defaults, so the values
# below are deliberately NOT the dev defaults: a real SECRET_KEY, a non-5173 CORS origin, and a
# distinct prod DB name (see backend/app/core/config.py::_validate_production_config).

# ── Database (its own prod DB + volume, host port 5434) ─────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meditationos_prod
# Inside the compose network the DB host is the service name `database`.
DATABASE_URL=postgresql://postgres:postgres@database:5432/meditationos_prod

# ── Backend (production mode) ───────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
# The prod frontend origin (host port 8080). Must NOT be the dev-default http://localhost:5173.
CORS_ORIGINS=http://localhost:8080
ACCESS_TOKEN_EXPIRE_MINUTES=60
WEB_CONCURRENCY=2
# Optional shared throttle store across workers (leave empty for in-memory).
REDIS_URL=

# ── Frontend build (VITE_* are inlined at build time) ───────────────────────────
# The browser reaches the host-mapped prod backend on port 8001.
VITE_API_URL=http://localhost:8001/api/v1
VITE_GOOGLE_CLIENT_ID=
VITE_SENTRY_DSN=
